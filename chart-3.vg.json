{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "background": "#f7f5f0",
    "width": 700,
    "height": 200,
    "data": {"url": "Coffe_sales.csv", "format": {"type": "csv"}},
    "params": [
      {
        "name": "selected_drink",
        "value": "All",
        "bind": {
          "input": "select",
          "options": ["All", "Latte", "Americano", "Espresso", "Cocoa"],
          "name": "Coffee type: "
        }
      }
    ],
    "transform": [
      {
        "filter": "selected_drink == 'All' || datum.coffee_name == selected_drink"
      },
      {
        "aggregate": [{"op": "count", "as": "orders"}],
        "groupby": ["Date"]
      }
    ],
    "layer": [
      {
        "mark": {
          "type": "line",
          "point": false,
          "color": "#6F4E37",
          "strokeWidth": 2
        },
        "encoding": {
          "x": {
            "field": "Date",
            "type": "temporal",
            "axis": {"title": "Date", "format": "%b", "labelAngle": 0}
          },
          "y": {
            "field": "orders",
            "type": "quantitative",
            "axis": {"title": "Orders"}
          },
          "tooltip": [
            {"field": "Date", "type": "temporal", "title": "Date"},
            {"field": "orders", "type": "quantitative", "title": "Orders"}
          ]
        }
      },
      {
        "transform": [
          {
            "filter": "selected_drink == 'All'"
          },
          {
            "window": [{"op": "rank", "as": "rank"}],
            "sort": [{"field": "orders", "order": "descending"}]
          },
          {
            "filter": "datum.rank == 1"
          }
        ],
        "mark": {
          "type": "point",
          "filled": true,
          "size": 90,
          "color": "#ff0101"
        },
        "encoding": {
          "x": {"field": "Date", "type": "temporal"},
          "y": {"field": "orders", "type": "quantitative"}
        }
      },
      {
        "transform": [
          {
            "filter": "selected_drink == 'All'"
          },
          {
            "window": [{"op": "rank", "as": "rank"}],
            "sort": [{"field": "orders", "order": "descending"}]
          },
          {
            "filter": "datum.rank == 1"
          },
          {
            "calculate": "'Overall peak: ' + datum.orders + ' orders'",
            "as": "label"
          }
        ],
        "mark": {
          "type": "text",
          "align": "left",
          "baseline": "bottom",
          "dx": 8,
          "dy": -8,
          "fontSize": 13,
          "fontWeight": "bold",
          "color": "#4A3525"
        },
        "encoding": {
          "x": {"field": "Date", "type": "temporal"},
          "y": {"field": "orders", "type": "quantitative"},
          "text": {"field": "label"}
        }
      }
    ]
  }